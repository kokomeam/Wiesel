# WiseSel — environment variables. Copy to .env.local and fill in.

# Supabase (browser-safe; project: mfqolkzocxssgogcmhzf)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — SERVER-ONLY. Required to enable the AI Content Agent. Never expose to
# the client (no NEXT_PUBLIC_ prefix). Without it, the agent route returns a
# clear "not configured" message.
OPENAI_API_KEY=
# Optional overrides:
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=medium
OPENAI_MAX_OUTPUT_TOKENS=16000
# Rate-limit hardening (the SDK retries 429/5xx with backoff + Retry-After):
OPENAI_MAX_RETRIES=5
OPENAI_TIMEOUT_MS=120000
# Agent step limits — per-turn cap + the whole-run call ceiling (module-build
# runaway guard); a run stops + emits a checkpoint when either is hit:
AGENT_MAX_TURNS=16
AGENT_MAX_TOTAL_CALLS=64

# Per-phase model + effort (lib/ai/modelConfig.ts). Defaults are CHEAP for
# testing — gpt-5.4-mini everywhere, CRITIQUE OFF. Premium models are a future
# tier hook; do not raise these for routine testing.
AI_PLAN_MODEL=gpt-5.4-mini
AI_PLAN_EFFORT=high
# MODULE builds now plan in TWO stages so no single call is huge: a compact
# SKELETON (lesson map — title/objective/slide-range per lesson, NO slide content)
# at LOW effort, then a RICH lesson plan per lesson LAZILY at generation time. The
# skeleton schema is tiny, so it returns in seconds (the old whole-module plan
# timed out during the model's long silent reasoning). Per-lesson GENERATE (medium)
# builds the depth.
AI_MODULE_PLAN_MODEL=gpt-5.4-mini
AI_MODULE_PLAN_EFFORT=low
# Plan calls are non-streaming with a longer timeout than a quick tool turn
# (client default OPENAI_TIMEOUT_MS is 120s).
AI_PLAN_TIMEOUT_MS=180000
# OPTIONAL OpenAI background mode for plan calls (create + POLL instead of holding
# one long HTTP connection through the model's reasoning — which an idle proxy can
# drop). OFF by default; the module FALLBACK plan uses it automatically after a
# skeleton timeout.
AI_USE_BACKGROUND_FOR_PLANS=false
AI_GENERATE_MODEL=gpt-5.4-mini
AI_GENERATE_EFFORT=medium
AI_EDIT_MODEL=gpt-5.4-mini
AI_EDIT_EFFORT=medium
# Legacy heavy CRITIQUE — OFF by default and superseded by VALIDATE/REPAIR below.
# Do not re-enable for routine generation.
AI_CRITIQUE_ENABLED=false
AI_CRITIQUE_MODEL=gpt-5.4-mini
AI_CRITIQUE_EFFORT=medium

# Deterministic VALIDATE/REPAIR — the correctness gate that enforces the plan
# contract after generation (catches the 3-slide deck, the leftover placeholder).
# Both default ON. AI_MAX_REPAIR_PASSES = targeted model-repair rounds before a
# checkpoint settles whatever was built.
AI_VALIDATE_GENERATION=true
AI_REPAIR_HARD_FAILURES=true
AI_MAX_REPAIR_PASSES=2
# Minimum slide floors a NON-micro lesson plan should hit (PLAN re-asks once if a
# normal/technical lesson comes back too thin). A micro-lesson is exempt.
AI_MIN_NORMAL_LESSON_SLIDES=6
AI_MIN_TECHNICAL_LESSON_SLIDES=7

# OPTIONAL lightweight review (ONE call, no tool loop, no regeneration) — NOT the
# old heavy critique. Returns soft suggestions only. OFF by default; with
# AI_LIGHT_REVIEW_ON_LINT_THRESHOLD it fires only when the deterministic linter
# raises ≥ AI_LIGHT_REVIEW_LINT_THRESHOLD warnings (a visibly rough deck).
AI_LIGHT_REVIEW_ENABLED=false
AI_LIGHT_REVIEW_ON_LINT_THRESHOLD=true
AI_LIGHT_REVIEW_LINT_THRESHOLD=4
AI_LIGHT_REVIEW_MODEL=gpt-5.4-mini
AI_LIGHT_REVIEW_EFFORT=medium

AI_CLASSIFIER_MODEL=gpt-5.4-mini
# Intent-router effort. gpt-5.4-mini does NOT accept "minimal" (none/low/medium/
# high/xhigh only), so keep this at "low" — the cheapest it supports.
AI_CLASSIFIER_EFFORT=low
# Product-tier hook (internal): draft | standard | premium (all map to the
# configs above for now).
AI_QUALITY_MODE=standard

# Bounded history (stop replaying the whole tool transcript each turn). `bounded`
# (default) injects a compact generation-state summary + the last K tool events;
# `full` restores the legacy whole-transcript replay (escape hatch / parity test).
AI_HISTORY_POLICY=bounded
AI_KEEP_RECENT_TOOL_EVENTS=4
AI_KEEP_RECENT_CHAT_MESSAGES=3
AI_MAX_STATE_SUMMARY_CHARS=8000
AI_MAX_TOOL_RESULT_CHARS=4000
# The EDIT path keeps a larger chat window + tool-result cap and drops the
# generation-state summary (edits stay scoped to the user's request):
AI_EDIT_KEEP_RECENT_CHAT_MESSAGES=8
AI_EDIT_MAX_TOOL_RESULT_CHARS=12000

# Site base URL (deep links in learner emails + the comms opt-out link).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Shared secret guarding the maintenance-agent cron drain route
# (Authorization: Bearer <CRON_SECRET> on POST /api/ai/maintenance/cron).
CRON_SECRET=
# Learner communications (Milestone 6). Email goes through lib/comms — Resend's
# REST API via fetch (no SDK). Without RESEND_API_KEY (or with
# COMMS_PROVIDER=mock) the mock provider records sends instead of sending.
RESEND_API_KEY=
RESEND_FROM="WiseSel <onboarding@resend.dev>"
# HMAC secret for the signed opt-out token in every learner email:
MARKETING_TOKEN_SECRET=
# COMMS_PROVIDER=mock
# Maintenance agent budgets (Milestone 5):
# MAINTENANCE_MAX_CONCURRENT_MODEL_CALLS=2
# MAINTENANCE_MAX_CALLS=40
# MAINTENANCE_MAX_TOKENS=300000

# Hard per-model-call deadline inside the MARKETING agent loop (chat stream +
# post-approval resumes). Without it a stalled transport hangs the run forever
# — the SDK's own timeout is ignored by the proxied fetch. Default 120000.
# MARKETING_AGENT_TURN_TIMEOUT_MS=120000

# ── Social Post Generator (Marketing Phase 1 — docs/social-posts.md) ──
# All optional. Daily budgets are config, not code constants:
# SOCIAL_MAX_BATCHES_PER_DAY=20
# SOCIAL_MAX_REVISIONS_PER_DAY=100
# Hard per-batch generation ceiling (quality-first, NOT a latency target;
# timeout => typed error, nothing persisted, parameters kept for retry):
# SOCIAL_GENERATION_TIMEOUT_MS=180000
# Source-context token budget (~4 chars/token):
# SOCIAL_CONTEXT_MAX_TOKENS=6000
# Model tiering (default: the provider's env default model; generation medium
# effort, revisions/hashtags/alt-text/voice low effort):
# SOCIAL_GENERATE_MODEL=
# SOCIAL_GENERATE_EFFORT=medium
# SOCIAL_REVISE_MODEL=
# SOCIAL_REVISE_EFFORT=low
